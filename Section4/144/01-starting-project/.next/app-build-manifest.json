{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/not-found.js"
    ],
    "/archive/@latest/default": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/archive/@latest/default.js"
    ],
    "/archive/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/archive/layout.js"
    ],
    "/archive/@archive/[[...filter]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/archive/@archive/[[...filter]]/page.js"
    ],
    "/superHuman/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/superHuman/layout.js"
    ],
    "/superHuman/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/superHuman/page.js"
    ],
    "/superHuman/@villain/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/superHuman/@villain/page.js"
    ],
    "/superHuman/@hero/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/superHuman/@hero/page.js"
    ],
    "/superHuman/@hero/[heroName]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/superHuman/@hero/[heroName]/page.js"
    ],
    "/news/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/news/page.js"
    ],
    "/news/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/news/not-found.js"
    ]
  }
}